#!/usr/bin/env bash

set -euo pipefail

if [[ -z "${TMUX:-}" ]]; then
	echo "This script must be run inside tmux so it can rename the current window." >&2
	exit 1
fi

if ! command -v tmux >/dev/null 2>&1; then
	echo "tmux is not available on PATH." >&2
	exit 1
fi

branch="$(git symbolic-ref --short HEAD 2>/dev/null || git rev-parse --short HEAD 2>/dev/null || true)"

if [[ -z "$branch" ]]; then
	echo "Not in a git repository (or no commits yet)." >&2
	exit 1
fi

name="${branch#evankirkiles--}"

tmux rename-window "$name"
