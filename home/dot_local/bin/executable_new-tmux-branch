#!/usr/bin/env bash

set -euo pipefail

usage() {
	echo "Usage: $(basename "$0") <name>" >&2
	exit 64
}

if [[ $# -ne 1 ]]; then
	usage
fi

name="$1"
branch="evankirkiles--${name}"

if [[ -z "$name" ]]; then
	usage
fi

if [[ -z "${TMUX:-}" ]]; then
	echo "This script must be run inside tmux so it can rename the current window." >&2
	exit 1
fi

if ! command -v tmux >/dev/null 2>&1; then
	echo "tmux is not available on PATH." >&2
	exit 1
fi

if ! tmux display-message -p '#W' >/dev/null 2>&1; then
	echo "Unable to talk to the current tmux session." >&2
	exit 1
fi

git rev-parse --show-toplevel >/dev/null
git remote get-url origin >/dev/null

if ! git check-ref-format --branch "$branch" >/dev/null; then
	echo "Invalid branch name: $branch" >&2
	exit 64
fi

if git show-ref --verify --quiet "refs/heads/$branch"; then
	echo "Local branch already exists: $branch" >&2
	exit 1
fi

git fetch origin "+refs/heads/main:refs/remotes/origin/main"
git switch --no-track --create "$branch" origin/main
git push --set-upstream origin "$branch"
tmux rename-window "$name"
