{{/* work around unreliable hostname on darwin */}}
{{- $hostname := .chezmoi.hostname -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   $hostname = output "scutil" "--get" "LocalHostName" | trim -}}
{{- end -}}

{{- $email := promptStringOnce . "email" "Git email address for the author/committer" "kirkilese@gmail.com" -}}
{{- $hostname := promptStringOnce . "hostname" "Hostname for the computer" $hostname -}}
{{- $languageChoices := list "frontend" "rust" "python" "go" -}}
{{- $languages := promptMultichoiceOnce . "languages" "Language ecosystems used on this computer" $languageChoices $languageChoices -}}

[data]
    email = {{ $email | quote }}
    hostname = {{ $hostname | quote }}
    languages = [{{ range $i, $lang := $languages }}{{ if $i }}, {{ end }}{{ $lang | quote }}{{ end }}]

[github]
    refreshPeriod = "12h"

[merge]
    command = "nvim"
    args = [
        "-d",
        {{ printf "%q" "{{ .Destination }}" }},
        {{ printf "%q" "{{ .Source }}" }},
        {{ printf "%q" "{{ .Target }}" }},
    ]
